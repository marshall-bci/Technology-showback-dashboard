# ============================================================
#  Technology Showback Dashboard — Environment Configuration
# ============================================================
# INSTRUCTIONS FOR THE SECURITY / INFRASTRUCTURE TEAM:
#
# 1. Copy this file and rename the copy to ".env" (no ".example").
# 2. Fill in the values below following the comments.
# 3. The ".env" file must NEVER be committed to git or shared over email.
#    Pass it to Azure App Service as Application Settings (not as a file).
#
# ── HOW TO DEPLOY (Azure Container — plug and play) ──────────────────────────
#
#   Step 1 — Build and push the container (run once from the repo root):
#     az acr build --registry <your-acr-name> --image showback-dashboard:latest .
#
#   Step 2 — Point App Service at the image (run once):
#     az webapp config container set \
#       --name <your-app-name> \
#       --resource-group <your-rg> \
#       --docker-custom-image-name <your-acr-name>.azurecr.io/showback-dashboard:latest
#
#   Step 3 — Set Application Settings in Azure Portal:
#     App Service → Configuration → Application Settings → add each variable below.
#     At minimum you need: APP_ENV, TRUST_ZSCALER_HEADERS, FRONTEND_URL,
#     ALLOWED_ORIGINS, JWT_SECRET_KEY, SESSION_SECRET.
#
#   Step 4 — Add the first admin user (run once after the container is live):
#     az webapp ssh --name <your-app-name> --resource-group <your-rg>
#     cd /app/backend
#     python init_admin.py admin@bci.ca
#     (Replace admin@bci.ca with the admin's actual BCI email address.)
#
#   Subsequent deployments: re-run Step 1 only. The container restarts automatically.
#
# ── MINIMUM REQUIRED SETTINGS FOR PRODUCTION ────────────────────────────────
#
#   APP_ENV=production
#   TRUST_ZSCALER_HEADERS=true
#   FRONTEND_URL=https://<your-app>.azurewebsites.net
#   ALLOWED_ORIGINS=https://<your-app>.azurewebsites.net
#   JWT_SECRET_KEY=<generate — see Section 2>
#   SESSION_SECRET=<generate — see Section 2>
#
# ── SETUP CHECKLIST ──────────────────────────────────────────────────────────
#   [1] Section 1b — Enable Zscaler trust      (security team — 1 setting)
#   [2] Section 2  — Generate secrets          (security team)
#   [3] Section 3  — Set production URLs       (infrastructure team)
#   [4] Section 4  — Database                  (optional: PostgreSQL for prod)
#   [5] Section 5  — Azure Blob Storage        (optional: persistent cost data)
#   [6] Section 6  — Azure Key Vault           (optional: secrets management)
#
#   NOTE: Section 1 (Azure AD) is NOT required. BCI uses Zscaler for authentication.
# ============================================================


# ── SECTION 1: Azure AD / Microsoft Entra ID (NOT required for BCI) ──────────
#
# BCI uses Zscaler Private Access (ZPA) for authentication — Section 1b below.
# These values are only needed if falling back to Microsoft OAuth login.
# Leave blank unless instructed by the security team.

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://your-app.azurewebsites.net/auth/callback


# ── SECTION 1b: Zscaler Private Access (ZPA) — PRIMARY AUTH FOR BCI ──────────
#
# When TRUST_ZSCALER_HEADERS=true, /auth/login reads the ZPA identity header
# and logs the user in directly — no Microsoft OAuth redirect needed.
# Users must still exist in the dashboard database with matching email.
#
# TRUST_ZSCALER_HEADERS:
#   false  — disabled (use Microsoft OAuth or /auth/dev-login in development)
#   true   — enabled  (set this in production once ZPA is confirmed working)
#
# ZSCALER_USER_HEADER: Leave as 'auto' — the app tries all common ZPA headers
#   automatically and uses the first one that contains a valid email address.
#   Only set this explicitly if you need to force a specific header name.
#   Headers tried in order: X-Zscaler-Auth-User, X-Forwarded-User, X-User-Email,
#   X-Auth-Request-Email, X-Remote-User

TRUST_ZSCALER_HEADERS=true
ZSCALER_USER_HEADER=auto


# ── SECTION 2: Security Keys ─────────────────────────────────────────────────
#
# WHO FILLS THIS: Security team
#
# JWT_SECRET_KEY: Signs the login tokens issued to each user after SSO.
#   Rotating this key will log out all active users.
#   Generate a new one: python -c "import secrets; print(secrets.token_hex(32))"
#
# SESSION_SECRET: Protects the OAuth state cookie during the login redirect.
#   Must be a DIFFERENT value from JWT_SECRET_KEY.
#   Generate: python -c "import secrets; print(secrets.token_hex(32))"
#
# IMPORTANT: Use different values for development and production environments.

JWT_SECRET_KEY=replace-with-64-char-hex-string
JWT_ALGORITHM=HS256

# How long a login session stays valid before requiring re-authentication.
# Default 480 = 8 hours (a full work day).
JWT_EXPIRE_MINUTES=480

SESSION_SECRET=replace-with-a-different-64-char-hex-string


# ── SECTION 3: Application Settings ─────────────────────────────────────────
#
# APP_ENV controls security behaviour:
#   development  — HTTP cookies allowed (no TLS required), used for local testing
#   production   — HTTPS-only cookies enforced, used for Azure deployment
#
# FRONTEND_URL: Where the React app is served from (used for post-login redirects).
#   Local dev:   http://localhost:5173
#   Production:  https://your-app.azurewebsites.net
#
# ALLOWED_ORIGINS: Comma-separated list of origins the API accepts requests from.
#   Add your production URL here when deploying.

APP_ENV=production

FRONTEND_URL=https://your-app.azurewebsites.net

ALLOWED_ORIGINS=https://your-app.azurewebsites.net


# ── SECTION 4: Database ───────────────────────────────────────────────────────
#
# LOCAL DEVELOPMENT — SQLite (default, no setup needed):
#   The file is auto-created at backend/data/app.db on first run.
#   Stores user accounts, permissions, and access logs.
#
# AZURE PRODUCTION — PostgreSQL:
#   Uncomment the PostgreSQL line and fill it in. Comment out the SQLite line.
#
#   How to get the PostgreSQL connection string from Azure:
#     Azure Portal → Azure Database for PostgreSQL → [your server]
#     → Connection strings → copy the "Python" or "psycopg2" string
#     Replace {your_password} with the actual password.

DATABASE_URL=sqlite:///./data/app.db

# DATABASE_URL=postgresql://username:password@hostname.postgres.database.azure.com:5432/dbname


# ── SECTION 5: Azure Blob Storage (production data storage) ──────────────────
#
# WHO FILLS THIS: Data management team (Azure Storage account owner)
#
# By default, uploaded cost data is saved to a local JSON file (backend/data/).
# In production, switch to Azure Blob Storage so all server instances share data.
#
# HOW TO ENABLE:
#   1. Uncomment the three lines below.
#   2. Set STORAGE_BACKEND=azure
#   3. Paste the connection string from Azure.
#
# How to get the connection string:
#   Azure Portal → Storage accounts → [your account]
#   → Security + networking → Access keys
#   → Click "Show" next to key1 → copy "Connection string"
#
# AZURE_STORAGE_CONTAINER: The blob container name (auto-created if it doesn't exist).

# STORAGE_BACKEND=azure
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=showback-data


# ── SECTION 6: Azure Key Vault (production secrets management) ────────────────
#
# WHO FILLS THIS: Security team
#
# For production, move JWT_SECRET_KEY, SESSION_SECRET, and AZURE_CLIENT_SECRET
# into Azure Key Vault instead of keeping them in this file.
#
# HOW TO ENABLE:
#   1. Store each secret in Key Vault using the exact variable names above
#      (e.g. create a secret named "JWT-SECRET-KEY").
#   2. Uncomment AZURE_KEY_VAULT_URL below and paste the Vault URI.
#   3. Assign the app's managed identity the "Key Vault Secrets User" role.
#
# How to get the Vault URI:
#   Azure Portal → Key vaults → [your vault] → Overview → "Vault URI"

# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
